{
  "trailingSlash": true,
  "rewrites": [
    { "source": "/docs/", "destination": "https://aide-docs.pages.dev/" },
    { "source": "/docs/:path*/", "destination": "https://aide-docs.pages.dev/:path*" },
    { "source": "/docs/:path*", "destination": "https://aide-docs.pages.dev/:path*" }
  ],
  "redirects": [
    { "source": "/getting-started/(.*)", "destination": "/docs/getting-started/$1", "permanent": false },
    { "source": "/commands/(.*)", "destination": "/docs/commands/$1", "permanent": false },
    { "source": "/guide/(.*)", "destination": "/docs/guide/$1", "permanent": false },
    { "source": "/arch/(.*)", "destination": "/docs/arch/$1", "permanent": false }
  ]
}
